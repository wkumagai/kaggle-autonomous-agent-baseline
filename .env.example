# ==============================================================================
# Kaggle-in-Kaggle Environment Configuration Template
# ==============================================================================
# Copy this file to .env and configure your API keys or proxy settings.

# ------------------------------------------------------------------------------
# Option 1: Direct Provider Mode (Recommended for local development)
# ------------------------------------------------------------------------------
# Provide your direct API keys for the LLM provider you wish to use.
# LiteLLM will automatically route calls to the official provider endpoints.

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------------------------
# Option 2: Kaggle Model Proxy Mode (Used during official competition runs)
# ------------------------------------------------------------------------------
# If you are evaluating through the Kaggle Model Proxy, configure the endpoint
# and proxy API key below. Omit these if using Direct Provider Mode (Option 1).

# MODEL_PROXY_URL=https://your-model-proxy-endpoint/v1
# MODEL_PROXY_API_KEY=your_proxy_api_key_here
